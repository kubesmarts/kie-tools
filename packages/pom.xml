<?xml version="1.0" encoding="UTF-8" ?>
<project
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://maven.apache.org/POM/4.0.0"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd"
>
  <parent>
    <groupId>org.apache.kie.sonataflow</groupId>
    <artifactId>kie-tools</artifactId>
    <version>111-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <modelVersion>4.0.0</modelVersion>
  <groupId>org.apache.kie.sonataflow</groupId>
  <artifactId>kie-tools-packages</artifactId>
  <packaging>pom</packaging>

  <properties>
    <skip.maven.deploy.in.pnpm>false</skip.maven.deploy.in.pnpm>
  </properties>

  <modules>
    <module>sonataflow-quarkus-devui</module>
    <module>sonataflow-management-console-webapp</module>
    <module>kogito-db-migrator-tool</module>
    <module>kogito-data-index-webapp</module>
    <module>kogito-jobs-service-webapp</module>
  </modules>

  <profiles>
    <profile>
      <id>full-build</id>
      <properties>
        <!-- This should make sure that if this profile is used in a mvn deploy execution,
             the Maven builds triggered by pnpm automation will not do any deployment.
             The only deployment that should happen should be from this profile's reactor,
             when it is used with mvn deploy. -->
        <skip.maven.deploy.in.pnpm>true</skip.maven.deploy.in.pnpm>
      </properties>
      <modules>
        <module>maven-base</module>
        <module>serverless-workflow-diagram-editor</module>
        <module>sonataflow-deployment-webapp</module>
        <module>dev-deployment-base-image</module>
        <module>jbpm-quarkus-devui</module>
        <module>vscode-java-code-completion-extension-plugin</module>
        <module>yard-model</module>
        <module>yard-validator-worker</module>
        <module>serverless-logic-web-tools-swf-deployment-quarkus-app</module>
        <module>sonataflow-quarkus-devui</module>
        <module>sonataflow-management-console-webapp</module>
        <module>kogito-db-migrator-tool</module>
        <module>kogito-data-index-webapp</module>
        <module>kogito-jobs-service-webapp</module>
      </modules>
    </profile>
  </profiles>
</project>
